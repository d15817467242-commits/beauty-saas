{
  "name": "meiye-saas",
  "version": "1.0.0",
  "description": "美业SaaS系统",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . MeiyeSaaS --platform=win32 --arch=x64 --out=dist --overwrite",
    "build": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.meiye.saas",
    "productName": "美业SaaS系统",
    "directories": {
      "output": "dist-exe"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
